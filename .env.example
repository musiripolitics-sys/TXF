# Copy to .env.local and fill in. .env.local is gitignored.

# Supabase project URL (Dashboard → Project Settings → Data API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Publishable / anon key — safe for the browser
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service-role / secret key — SERVER ONLY. Bypasses RLS. Never expose to client.
SUPABASE_SERVICE_ROLE_KEY=
